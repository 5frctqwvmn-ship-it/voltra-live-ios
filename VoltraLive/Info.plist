<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>VOLTRA Live</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>0.4.37</string>
    <key>CFBundleVersion</key>
    <string>59</string>
    <!-- Build 31: short label for the single feature this build is testing.
         Shown next to the build badge in every screen so the user knows
         exactly what to focus on. Update this each build to match the one
         feature being tested. Empty string disables the label. -->
    <key>VOLTRAFeatureLabel</key>
    <string>b59: route to V2 when both Voltras paired (b58 dual UI was hidden)</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- v0.4.6.3: Demo Mode trace upload. release.yml replaces these
         placeholders with values from GitHub Secrets at build time so no
         endpoint/token ships in the source tree. Empty strings are valid;
         the iOS uploader will surface a clear error. -->
    <key>DemoTraceEndpoint</key>
    <string>__DEMO_TRACE_ENDPOINT__</string>
    <key>DemoTraceSharedToken</key>
    <string>__DEMO_TRACE_SHARED_TOKEN__</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>VOLTRA Live needs Bluetooth to connect to your VOLTRA device and receive live workout telemetry.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>VOLTRA Live needs Bluetooth to connect to your VOLTRA device.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>VOLTRA Live reads heart rate and active energy from your Apple Watch workout so you can see live BPM and calories during a session.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>VOLTRA Live does not write to Health — this entry is required by the platform.</string>
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string></string>
    </dict>
    <key>UIRequiresFullScreen</key>
    <false/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIUserInterfaceStyle</key>
    <string>Dark</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
